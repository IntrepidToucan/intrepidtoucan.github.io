---
import "../styles/reset.css";
import "../styles/variables.css";
import "../styles/global.css";

export interface Props {
  title: string;
}

const { title } = Astro.props;
---

<!DOCTYPE html>
<html lang="en-us">
  <head>
    <meta charset="utf-8" />
    <meta name="generator" content={Astro.generator} />
    <meta name="viewport" content="width=device-width, initial-scale=1" />

    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />

    <title>{title} | IntrepidToucan</title>
  </head>

  <body class="theme-light">
    <div class="app-shell">
      <header class="app-header">
        <a aria-label="Home" class="home-link" href="/">IntrepidToucan</a>
      </header>

      <main>
        <slot />
      </main>

      <footer class="app-footer">
        <span class="copyright-statement">
          Copyright © 2022 IntrepidToucan. All rights reserved.
        </span>
      </footer>
    </div>
  </body>
</html>

<style>
  .app-footer {
    margin-block-start: auto;
    padding-block: var(--spacing-4);
    padding-inline: var(--spacing-4);
    text-align: center;
  }

  .app-header {
    align-items: center;
    display: flex;
    min-height: var(--sizing-8);
    padding-block: var(--spacing-3);
    padding-inline: var(--spacing-4);
  }

  .app-shell {
    display: flex;
    flex-direction: column;
    height: 100%;
  }

  .copyright-statement {
    font-size: var(--font-size-1);
  }

  .home-link {
    color: inherit;
    font-family: var(--font-family-serif);
    font-size: var(--font-size-4);
    font-weight: var(--font-weight-2);
    text-decoration: none;
  }

  .home-link:hover {
    text-decoration-color: var(--color-primary-1-3);
    text-decoration-line: underline;
    text-decoration-thickness: var(--border-width-3);
  }
</style>
