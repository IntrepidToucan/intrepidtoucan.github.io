---
import HeroBanner from "../components/HeroBanner.astro";
import HomePageSection from "../components/HomePageSection.astro";
import AppLayout from "../layouts/AppLayout.astro";
---

<AppLayout>
  <HeroBanner
    backgroundPatternSrc="url('/images/patterns/primary-topography.svg')"
    smallTitle="Intrepid Toucan"
    subtitle="Adventures in Worldbuilding"
    title="IntrepidToucan"
  />

  <HomePageSection
    backgroundPatternSrc="url('/images/patterns/alpha-temple.svg')"
    ctaColor="var(--color-alpha-1-4)"
    ctaColorActive="var(--color-alpha-1-5)"
    ctaColorHover="var(--color-alpha-1-3)"
    href="/alpha"
    text={[
      "Project Alpha is a fantasy saga set in a world of rich cultures, powerful gods, political machinations, and thrilling combat.",
    ]}
    title="Project Alpha"
  />
</AppLayout>
