---
import AppLayout from "../layouts/AppLayout.astro";
---

<AppLayout title="Home">
  <div class="page-container">
    <div class="hero-banner">
      <h1 class="hero-title only-large">IntrepidToucan</h1>
      <h1 class="hero-title only-small">Intrepid Toucan</h1>
    </div>

    <div class="page-section page-section-alpha">
      <h2 class="section-title">Project Alpha</h2>

      <p class="section-text">
        Lorem ipsum... Lorem ipsum... Lorem ipsum... Lorem ipsum... Lorem
        ipsum... Lorem ipsum... Lorem ipsum... Lorem ipsum... Lorem ipsum...
      </p>

      <p class="section-text">
        Lorem ipsum... Lorem ipsum... Lorem ipsum... Lorem ipsum... Lorem
        ipsum... Lorem ipsum... Lorem ipsum... Lorem ipsum... Lorem ipsum...
      </p>

      <a class="button-link button-link-alpha" href="#alpha">Explore</a>
    </div>
  </div>
</AppLayout>

<style>
  .button-link {
    align-items: center;
    align-self: center;
    border-radius: var(--border-radius-1);
    box-shadow: var(--box-shadow-compound-2);
    color: var(--color-neutral-0);
    display: inline-flex;
    font-size: var(--font-size-4);
    font-weight: var(--font-weight-2);
    justify-content: center;
    margin-block-start: var(--spacing-2);
    min-height: var(--sizing-8);
    min-width: var(--sizing-11);
    padding-block: var(--spacing-4);
    padding-inline: var(--spacing-5);
    text-decoration: none;
    transition: background-color var(--transition-duration-1);
  }

  .button-link:active {
    box-shadow: var(--box-shadow-compound-1);
  }

  .button-link-alpha {
    background-color: var(--color-alpha-1-4);
  }

  .button-link-alpha:hover {
    background-color: var(--color-alpha-1-3);
  }

  .button-link-alpha:active {
    background-color: var(--color-alpha-1-5);
  }

  .hero-banner {
    background-color: var(--color-neutral-9);
    color: var(--color-neutral-0);
    display: flex;
    flex-direction: column;
    justify-content: center;
    min-height: var(--sizing-14);
    padding-block: var(--spacing-5);
    padding-inline: var(--spacing-4);
  }

  .hero-title {
    background-clip: text;
    background-image: linear-gradient(
      45deg,
      var(--color-primary-1-5) 30%,
      var(--color-primary-1-1) 80%
    );
    color: transparent;
    font-size: var(--font-size-8);
    text-align: center;
  }

  .only-large {
    display: none;
  }

  .page-container {
    background-color: var(--color-neutral-1);
    height: 100%;
  }

  .page-section {
    display: flex;
    flex-direction: column;
    gap: var(--spacing-4);
    justify-content: space-between;
    min-height: var(--sizing-13);
    padding-block-end: var(--spacing-6);
    padding-block-start: var(--spacing-5);
    padding-inline: var(--spacing-4);
  }

  .page-section-alpha {
    background-color: var(--color-neutral-0);
  }

  .section-text {
    color: var(--color-neutral-6);
    font-size: var(--font-size-3);
    margin-block-end: var(--spacing-2);
  }

  .section-title {
    font-size: var(--font-size-6);
    text-align: center;
  }

  @media (min-width: 414px) {
    .hero-banner {
      min-height: var(--sizing-15);
    }

    .only-large {
      display: initial;
    }

    .only-small {
      display: none;
    }

    .page-section {
      min-height: var(--sizing-14);
    }
  }

  @media (min-width: 768px) {
    .hero-banner {
      min-height: var(--sizing-16);
    }

    .hero-title {
      font-size: var(--font-size-9);
    }

    .page-section {
      min-height: var(--sizing-15);
      padding-block-end: var(--spacing-7);
      padding-block-start: var(--spacing-6);
      padding-inline: var(--spacing-6);
    }

    .section-title {
      font-size: var(--font-size-7);
    }
  }
</style>
