---
import HeroBanner from "../components/HeroBanner.astro";
import AppLayout from "../layouts/AppLayout.astro";
---

<AppLayout title="Home">
  <HeroBanner
    patternSrc="url('/images/patterns/primary-topography.svg')"
    smallTitle="Intrepid Toucan"
    subtitle="Adventures in Worldbuilding"
    title="IntrepidToucan"
  />

  <div class="page-section page-section-alpha">
    <h2 class="section-title">Project Alpha</h2>

    <p class="section-text">
      Project Alpha is a fantasy saga set in a world of rich cultures, powerful
      gods, political machinations, and thrilling combat.
    </p>

    <a class="button-link button-link-alpha" href="/alpha">Explore</a>
  </div>
</AppLayout>

<style>
  .button-link {
    align-items: center;
    border-radius: var(--border-radius-1);
    box-shadow: var(--box-shadow-compound-2);
    color: var(--color-neutral-0);
    display: inline-flex;
    font-size: var(--font-size-4);
    font-weight: var(--font-weight-2);
    justify-content: center;
    margin-block-start: var(--spacing-4);
    min-block-size: var(--sizing-8);
    min-inline-size: var(--sizing-11);
    padding-block: var(--spacing-4);
    padding-inline: var(--spacing-5);
    text-decoration: none;
    transition: background-color var(--transition-duration-1);
  }

  .button-link:active {
    box-shadow: var(--box-shadow-compound-1);
  }

  .button-link-alpha {
    background-color: var(--color-alpha-1-4);
  }

  .button-link-alpha:hover {
    background-color: var(--color-alpha-1-3);
  }

  .button-link-alpha:active {
    background-color: var(--color-alpha-1-5);
  }

  .page-section {
    align-items: center;
    display: flex;
    flex-direction: column;
    gap: var(--spacing-6);
    justify-content: space-between;
    min-block-size: var(--sizing-13);
    padding-block-end: var(--spacing-8);
    padding-block-start: var(--spacing-7);
    padding-inline: var(--spacing-4);
  }

  .page-section-alpha {
    background-color: var(--color-neutral-0);
    background-image: linear-gradient(
        0deg,
        transparent 20%,
        var(--color-neutral-0) 45%
      ),
      url("/images/patterns/alpha-temple.svg");
  }

  .section-text {
    color: var(--color-neutral-6);
    font-size: var(--font-size-4);
    font-weight: var(--font-weight-0);
    max-inline-size: 30em;
  }

  .section-title {
    font-size: var(--font-size-6);
    text-align: center;
  }

  @media (min-width: 768px) {
    .page-section {
      gap: var(--spacing-7);
      padding-block-start: var(--spacing-8);
      padding-inline: var(--spacing-5);
    }

    .section-text {
      font-size: var(--font-size-5);
    }

    .section-title {
      font-size: var(--font-size-7);
    }
  }
</style>
