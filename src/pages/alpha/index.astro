---
import HeroBanner from "../../components/HeroBanner.astro";
import ImageDiv from "../../components/ImageDiv.astro";
import AppLayout from "../../layouts/AppLayout.astro";

const placeEntries = (await Astro.glob("./places/*.mdx")).filter((entry) => {
  const pathSegments = entry.url?.split("/");

  if (!pathSegments) return false;

  // Filter out subsection files.
  return !pathSegments[pathSegments.length - 1]?.includes("--");
});

const cityEntries = placeEntries.filter((entry) => {
  const tags = entry.frontmatter.tags;

  if (!Array.isArray(tags)) return false;

  return tags.includes("city");
});
---

<AppLayout title="Project Alpha">
  <HeroBanner
    backgroundPatternSrc="url('/images/patterns/primary-temple.svg')"
    title="Project Alpha"
  />

  <div class="page-section">
    <div class="section-wrapper">
      <h2 class="section-title">Cities</h2>

      <p class="section-text">
        Lorem ipsum dolor sit amet, consectetur adipiscing elit, sed do eiusmod
        tempor incididunt ut labore et dolore magna aliqua.
      </p>

      <div class="image-grid image-grid-places">
        {
          cityEntries.map((entry) => (
            <ImageDiv
              backgroundImageSrc={`url("${entry.frontmatter.image.thumbnail}")`}
              class="image-place"
              href={entry.url}
            />
          ))
        }
      </div>
    </div>
  </div>

  <div class="page-section">
    <div class="section-wrapper">
      <h2 class="section-title">Gods</h2>

      <p class="section-text">
        Lorem ipsum dolor sit amet, consectetur adipiscing elit, sed do eiusmod
        tempor incididunt ut labore et dolore magna aliqua.
      </p>

      <div class="image-grid image-grid-people">
        {
          placeEntries.map((entry) => (
            <ImageDiv
              backgroundImageSrc={`url("${entry.frontmatter.image.thumbnail}")`}
              class="image-person"
              href={entry.url}
            />
          ))
        }
      </div>
    </div>
  </div>

  <div class="page-section">
    <div class="section-wrapper">
      <h2 class="section-title">People</h2>

      <p class="section-text">
        Lorem ipsum dolor sit amet, consectetur adipiscing elit, sed do eiusmod
        tempor incididunt ut labore et dolore magna aliqua.
      </p>

      <div class="image-grid image-grid-people">
        {
          placeEntries.map((entry) => (
            <ImageDiv
              backgroundImageSrc={`url("${entry.frontmatter.image.thumbnail}")`}
              class="image-person"
              href={entry.url}
            />
          ))
        }
      </div>
    </div>
  </div>
</AppLayout>

<style>
  .image-grid {
    display: flex;
    flex-wrap: wrap;
    gap: var(--spacing-5);
    margin-block-start: var(--spacing-6);
    margin-inline: auto;
  }

  .image-grid-people {
    max-width: 250px;
  }

  .image-grid-places {
    max-width: 400px;
  }

  .image-person {
    height: 300px;
  }

  .image-place {
    height: 250px;
  }

  .page-section {
    padding-block-end: var(--spacing-8);
    padding-block-start: var(--spacing-7);
    padding-inline: var(--app-padding-inline-small);
  }

  .page-section:nth-child(odd) {
    background-color: var(--color-neutral-9);
  }

  .page-section:nth-child(odd) .section-text {
    color: var(--color-neutral-2);
  }

  .page-section:nth-child(odd) .section-title {
    color: var(--color-neutral-0);
  }

  .section-text {
    color: var(--color-neutral-7);
    max-inline-size: 30em;
  }

  .section-title {
    font-size: var(--font-size-6);
  }

  @media (min-width: 556px) {
    .image-person {
      max-width: 250px;
    }

    .image-grid-people {
      max-width: 524px;
    }
  }

  @media (min-width: 768px) {
    .page-section {
      padding-block-end: var(--spacing-9);
      padding-block-start: var(--spacing-8);
      padding-inline: var(--app-padding-inline-large);
    }

    .section-text {
      font-size: var(--font-size-3);
    }

    .section-title {
      font-size: var(--font-size-7);
    }

    .section-wrapper {
      margin-inline: auto;
      max-inline-size: var(--app-content-max-inline-size);
    }
  }

  @media (min-width: 846px) {
    .image-grid-people {
      max-width: 798px;
    }
  }

  @media (min-width: 872px) {
    .image-place {
      max-width: 400px;
    }

    .image-grid-places {
      max-width: 825px;
    }
  }

  @media (min-width: 1120px) {
    .image-grid-people {
      max-width: 1072px;
    }
  }

  @media (min-width: 1296px) {
    .image-grid {
      max-width: none;
    }
  }
</style>
